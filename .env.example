APP_NAME=Baoyan Agent
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# mock is the default and works without any API key.
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# DashScope OpenAI-compatible mode. Keep real keys only in local .env.
DASHSCOPE_API_KEY=
# LLM_PROVIDER=dashscope
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-vl-max
# LLM_CRITIC_MODEL=qwen3.6-flash
# LLM_CRITIC_MAX_TOKENS=400
# LLM_PLANNER_MODEL=qwen3.6-flash
# LLM_PLANNER_MAX_TOKENS=500
# LLM_MEMBER_C_FALLBACK_MODEL=qwen3.6-flash
# LLM_MEMBER_C_MODEL=qwen3.6-flash
# LLM_MEMBER_C_TIMEOUT_SECONDS=45
# LLM_MEMBER_C_MAX_TOKENS=1200
# Member C MCP service. The business API uses this URL and falls back locally if enabled.
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8002
MCP_SERVER_URL=http://127.0.0.1:8002/mcp
MCP_TIMEOUT_SECONDS=8
MCP_LOCAL_FALLBACK=true
